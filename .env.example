NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
API_PREFIX=/api/v1

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/unilife?retryWrites=true&w=majority

# JWT
JWT_ACCESS_SECRET=replace_with_strong_access_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
MAIL_FROM=UniLife <your_gmail@gmail.com>

# Upload local
UPLOAD_ROOT=uploads
AVATAR_UPLOAD_DIR=uploads/avatars
FOOD_UPLOAD_DIR=uploads/foods
MAX_FILE_SIZE_MB=5

# Sepay placeholder
SEPAY_API_BASE_URL=https://my.sepay.vn
SEPAY_API_KEY=replace_with_sepay_api_key
SEPAY_WEBHOOK_SECRET=replace_with_sepay_webhook_secret

# Default admin seed
ADMIN_FULL_NAME=System Admin
ADMIN_EMAIL=admin@unilife.local
ADMIN_PASSWORD=Admin@123456
